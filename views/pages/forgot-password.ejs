<div class="row justify-content-center">
  <div class="col-md-8 col-lg-5">
    <div class="card shadow-sm border-0 rounded-4">
      <div class="card-body p-4 p-lg-5">
        <h1 class="h3 fw-bold mb-3">Forgot password</h1>
        <p class="text-secondary">
          Enter your email address and we will send you a password reset link.
        </p>

        <% if (authFeedback) { %>
          <div class="alert alert-<%= authFeedback.type %> mt-4" role="alert">
            <h2 class="h6 fw-bold mb-2"><%= authFeedback.title %></h2>
            <ul class="mb-0 ps-3">
              <% authFeedback.messages.forEach((message) => { %>
                <li><%= message %></li>
              <% }) %>
            </ul>
          </div>
        <% } %>

        <form class="mt-4" action="/auth/forgot-password" method="POST" novalidate>
          <div class="mb-3">
            <label for="forgotEmail" class="form-label">Email</label>
            <input
              id="forgotEmail"
              name="email"
              type="email"
              class="form-control"
              placeholder="name@example.com"
              value="<%= authFeedback?.values?.email || '' %>"
              required
            />
          </div>

          <button type="submit" class="btn btn-primary w-100">Send reset link</button>
        </form>

        <p class="text-secondary small mt-4 mb-0">
          Back to
          <a href="/login" class="fw-semibold text-decoration-none">Login</a>
        </p>
      </div>
    </div>
  </div>
</div>