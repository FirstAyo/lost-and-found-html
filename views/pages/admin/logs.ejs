<section>
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
      <h1 class="h2 fw-bold mb-1">Accountability Logs</h1>
      <p class="text-secondary mb-0">Review who did what, when it happened, and whether the action succeeded or was blocked.</p>
    </div>
    <a href="/admin/dashboard" class="btn btn-outline-primary">Back to Admin Dashboard</a>
  </div>

  <% if (adminFeedback) { %>
    <div class="alert alert-<%= adminFeedback.type %> border-0 shadow-sm" role="alert">
      <h2 class="h6 mb-2"><%= adminFeedback.title %></h2>
      <% adminFeedback.messages.forEach((message) => { %>
        <p class="mb-0"><%= message %></p>
      <% }) %>
    </div>
  <% } %>

  <div class="row g-3 mb-4">
    <div class="col-md-6 col-xl-3"><div class="card border-0 shadow-sm admin-stat-card"><div class="card-body"><span class="text-secondary small">Total Logs</span><h2 class="display-6 fw-bold mb-0"><%= summary.totals.totalLogs %></h2></div></div></div>
    <div class="col-md-6 col-xl-3"><div class="card border-0 shadow-sm admin-stat-card"><div class="card-body"><span class="text-secondary small">Successful</span><h2 class="display-6 fw-bold mb-0"><%= summary.totals.successLogs %></h2></div></div></div>
    <div class="col-md-6 col-xl-3"><div class="card border-0 shadow-sm admin-stat-card"><div class="card-body"><span class="text-secondary small">Blocked</span><h2 class="display-6 fw-bold mb-0"><%= summary.totals.blockedLogs %></h2></div></div></div>
    <div class="col-md-6 col-xl-3"><div class="card border-0 shadow-sm admin-stat-card"><div class="card-body"><span class="text-secondary small">Failures</span><h2 class="display-6 fw-bold mb-0"><%= summary.totals.failureLogs %></h2></div></div></div>
  </div>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
      <form method="GET" action="/admin/logs" class="row g-3 align-items-end">
        <div class="col-md-5">
          <label for="search" class="form-label">Search</label>
          <input id="search" name="search" class="form-control" value="<%= filters.search %>" placeholder="Search by action or route" />
        </div>
        <div class="col-md-3">
          <label for="outcome" class="form-label">Outcome</label>
          <select id="outcome" name="outcome" class="form-select">
            <option value="">All outcomes</option>
            <option value="success" <%= filters.outcome === 'success' ? 'selected' : '' %>>Success</option>
            <option value="blocked" <%= filters.outcome === 'blocked' ? 'selected' : '' %>>Blocked</option>
            <option value="failure" <%= filters.outcome === 'failure' ? 'selected' : '' %>>Failure</option>
          </select>
        </div>
        <div class="col-md-2">
          <label for="userRole" class="form-label">Role</label>
          <select id="userRole" name="userRole" class="form-select">
            <option value="">All roles</option>
            <option value="guest" <%= filters.userRole === 'guest' ? 'selected' : '' %>>Guest</option>
            <option value="member" <%= filters.userRole === 'member' ? 'selected' : '' %>>Member</option>
            <option value="admin" <%= filters.userRole === 'admin' ? 'selected' : '' %>>Admin</option>
          </select>
        </div>
        <div class="col-md-2 d-grid">
          <button type="submit" class="btn btn-primary">Apply</button>
        </div>
      </form>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="table-responsive">
      <table class="table align-middle mb-0 admin-table">
        <thead>
          <tr>
            <th>Action</th>
            <th>Outcome</th>
            <th>User Role</th>
            <th>Route</th>
            <th>Status</th>
            <th>Time</th>
          </tr>
        </thead>
        <tbody>
          <% if (summary.recentLogs.length > 0) { %>
            <% summary.recentLogs.forEach((log) => { %>
              <tr>
                <td>
                  <div class="fw-semibold"><%= log.action %></div>
                  <% if (log.metadata?.title) { %>
                    <div class="small text-secondary"><%= log.metadata.title %></div>
                  <% } %>
                </td>
                <td><span class="badge <%= log.outcome === 'success' ? 'text-bg-success' : log.outcome === 'blocked' ? 'text-bg-warning' : 'text-bg-danger' %>"><%= log.outcome %></span></td>
                <td><span class="badge text-bg-light text-dark"><%= log.userRole %></span></td>
                <td>
                  <div class="small text-secondary"><%= log.method %></div>
                  <div><%= log.route %></div>
                </td>
                <td><%= log.statusCode %></td>
                <td><%= new Date(log.createdAt).toLocaleString() %></td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="6" class="text-center py-4 text-secondary">No accountability logs found yet.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</section>
