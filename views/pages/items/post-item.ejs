<section class="container">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
      <p class="text-uppercase small fw-semibold text-primary mb-1"><%= itemType === 'lost' ? 'Lost item' : 'Found item' %></p>
      <h1 class="h2 fw-bold mb-2"><%= formTitle %></h1>
      <p class="text-secondary mb-0"><%= formSubtitle %></p>
    </div>
    <a href="/items/mine" class="btn btn-outline-secondary">Back to my listings</a>
  </div>

  <% if (itemFeedback) { %>
    <div class="alert alert-<%= itemFeedback.type %> mb-4" role="alert">
      <h2 class="h6 fw-bold mb-2"><%= itemFeedback.title %></h2>
      <ul class="mb-0 ps-3">
        <% itemFeedback.messages.forEach((message) => { %>
          <li><%= message %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4 p-lg-5">
      <form class="row g-4" method="POST" action="<%= formAction %>" enctype="multipart/form-data">
        <div class="col-md-6">
          <label for="title" class="form-label">Item title</label>
          <input id="title" name="title" type="text" class="form-control" value="<%= itemFeedback?.values?.title || values.title %>" placeholder="Black leather wallet" required />
        </div>
        <div class="col-md-6">
          <label for="category" class="form-label">Category</label>
          <select id="category" name="category" class="form-select form-control" required>
            <option value="">Choose a category</option>
            <% categories.forEach((category) => { %>
              <option value="<%= category %>" <%= (itemFeedback?.values?.category || values.category) === category ? 'selected' : '' %>><%= category %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-6">
          <label for="incidentDate" class="form-label"><%= itemType === 'lost' ? 'Date lost' : 'Date found' %></label>
          <input id="incidentDate" name="incidentDate" type="date" class="form-control" value="<%= itemFeedback?.values?.incidentDate || values.incidentDate %>" required />
        </div>
        <div class="col-md-6">
          <label for="location" class="form-label"><%= itemType === 'lost' ? 'Last seen location' : 'Found location' %></label>
          <input id="location" name="location" type="text" class="form-control" value="<%= itemFeedback?.values?.location || values.location %>" placeholder="Library, downtown station, campus..." required />
        </div>
        <div class="col-12">
          <label for="image" class="form-label">Item photo <%= isEditing ? '(upload a new file only if you want to replace the current image)' : '(optional)' %></label>
          <input id="image" name="image" type="file" class="form-control" accept="image/png,image/jpeg,image/webp" />
          <div class="form-text">Accepted formats: JPG, PNG, WebP. Maximum size: 3 MB.</div>
        </div>

        <% if (isEditing && existingImagePath) { %>
          <div class="col-12">
            <div class="card border rounded-4 bg-light-subtle">
              <div class="card-body d-flex flex-column flex-md-row align-items-md-center gap-3">
                <img src="<%= existingImagePath %>" alt="Current item image" class="rounded-3 object-fit-cover" style="width: 120px; height: 90px;" />
                <div>
                  <p class="fw-semibold mb-1">Current image</p>
                  <p class="text-secondary small mb-0">Leave the upload field empty to keep this image.</p>
                </div>
              </div>
            </div>
          </div>
        <% } %>

        <div class="col-12">
          <label for="description" class="form-label">Description</label>
          <textarea id="description" name="description" class="form-control post-item-textarea" rows="6" placeholder="Describe the item, colors, identifying marks, and anything else useful." required><%= itemFeedback?.values?.description || values.description %></textarea>
        </div>
        <div class="col-12 d-flex justify-content-end gap-2">
          <a href="/items/mine" class="btn btn-outline-secondary">Cancel</a>
          <button type="submit" class="btn btn-primary"><%= submitLabel %></button>
        </div>
      </form>
    </div>
  </div>
</section>
