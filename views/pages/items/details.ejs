<section class="container">
  <div class="row g-4 align-items-start">
    <div class="col-lg-6">
      <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="ratio ratio-4x3 item-details-media">
          <% if (item.imagePath) { %>
            <img src="<%= item.imagePath %>" class="w-100 h-100 object-fit-cover" alt="<%= item.title %>" />
          <% } else { %>
            <div class="d-flex align-items-center justify-content-center text-secondary fw-semibold bg-light">No image provided</div>
          <% } %>
        </div>
      </div>
    </div>

    <div class="col-lg-6">
      <div class="card border-0 shadow-sm rounded-4 h-100">
        <div class="card-body p-4 p-lg-5">
          <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
            <div>
              <p class="text-uppercase small fw-semibold text-primary mb-1"><%= item.type %> item</p>
              <h1 class="display-6 fw-bold mb-0"><%= item.title %></h1>
            </div>
            <div class="d-flex flex-column gap-2 align-items-end">
              <span class="badge rounded-pill text-bg-<%= item.type === 'lost' ? 'warning' : 'success' %>"><%= item.type %></span>
              <span class="badge text-bg-<%= item.isResolved ? 'secondary' : 'primary' %>"><%= item.status %></span>
            </div>
          </div>

          <div class="row g-3 small item-details-meta mb-4">
            <div class="col-sm-6"><strong>Category:</strong> <%= item.category %></div>
            <div class="col-sm-6"><strong>Status:</strong> <%= item.status %></div>
            <div class="col-sm-6"><strong>Location:</strong> <%= item.location %></div>
            <div class="col-sm-6"><strong>Date:</strong> <%= item.incidentDate %></div>
            <div class="col-12"><strong>Posted by:</strong> <%= item.ownerName %></div>
          </div>

          <h2 class="h5 fw-bold">Description</h2>
          <p class="text-secondary mb-4"><%= item.description %></p>

          <div class="d-flex gap-2 flex-wrap mb-3">
            <a href="/browse" class="btn btn-outline-secondary">Back to browse</a>
            <% if (currentUser) { %>
              <a href="/items/mine" class="btn btn-primary">Go to dashboard</a>
            <% } else { %>
              <a href="/register" class="btn btn-primary">Create account to post</a>
            <% } %>
          </div>

          <% if (canManageItem) { %>
            <hr class="my-4" />
            <div class="d-flex gap-2 flex-wrap">
              <a href="/items/<%= item.id %>/edit" class="btn btn-outline-secondary">Edit this listing</a>
              <% if (!item.isResolved) { %>
                <form method="POST" action="/items/<%= item.id %>/resolve">
                  <button type="submit" class="btn btn-success">Mark resolved</button>
                </form>
              <% } %>
              <form method="POST" action="/items/<%= item.id %>/delete" onsubmit="return confirm('Delete this listing permanently?');">
                <button type="submit" class="btn btn-outline-danger">Delete</button>
              </form>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</section>
