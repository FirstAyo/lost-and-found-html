<article class="card item-card border-0 h-100 shadow-sm">
  <div class="item-card__media ratio ratio-4x3">
    <% if (item.imagePath) { %>
      <img src="<%= item.imagePath %>" class="w-100 h-100 object-fit-cover" alt="<%= item.title %>" />
    <% } else { %>
      <div class="item-card__placeholder d-flex align-items-center justify-content-center fw-semibold text-secondary">
        No image
      </div>
    <% } %>
  </div>

  <div class="card-body d-flex flex-column">
    <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
      <h3 class="h5 mb-0"><%= item.title %></h3>
      <span class="badge rounded-pill text-bg-<%= item.type === 'lost' ? 'warning' : 'success' %>">
        <%= item.type %>
      </span>
    </div>

    <p class="small text-secondary mb-2">
      <%= item.category %> • <%= item.location %>
    </p>

    <% if (item.type === 'found' && item.pickupLocationLabel) { %>
      <p class="small mb-2">
        <strong>Pickup:</strong> <%= item.pickupLocationLabel %>
      </p>
    <% } %>

    <p class="item-card__description text-secondary flex-grow-1">
      <%= item.description %>
    </p>

    <!-- Bottom section -->
    <div class="mt-3">

      <div class="d-flex justify-content-between align-items-center mb-2">
        <span class="small text-muted"><%= item.incidentDate %></span>
        <a href="/items/<%= item.id %>" class="btn btn-sm btn-outline-primary">
          View details
        </a>
      </div>

      <!-- OWNER ACTIONS -->
      <% if (typeof showOwnerActions !== 'undefined' && showOwnerActions) { %>
        <div class="d-flex gap-2 flex-wrap">

          <!-- Edit -->
          <a href="/items/edit/<%= item.id %>" class="btn btn-sm btn-outline-secondary">
            Edit
          </a>

          <!-- Mark as Resolved -->
          <% if (item.status !== 'resolved') { %>
            <form action="/items/resolve/<%= item.id %>" method="POST">
              <button type="submit" class="btn btn-sm btn-success">
                Mark Resolved
              </button>
            </form>
          <% } %>

          <!-- Delete -->
          <form action="/items/delete/<%= item.id %>" method="POST" onsubmit="return confirm('Delete this item?');">
            <button type="submit" class="btn btn-sm btn-danger">
              Delete
            </button>
          </form>

        </div>
      <% } %>

    </div>
  </div>
</article>