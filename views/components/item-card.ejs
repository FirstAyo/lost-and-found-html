<% const ownerActionsEnabled = typeof showOwnerActions !== 'undefined' ? showOwnerActions : false; %>

<article class="card item-card border-0 h-100 shadow-sm">
  <div class="item-card__media ratio ratio-4x3">
    <% if (item.imagePath) { %>
      <img src="<%= item.imagePath %>" class="w-100 h-100 object-fit-cover" alt="<%= item.title %>" />
    <% } else { %>
      <div class="item-card__placeholder d-flex align-items-center justify-content-center fw-semibold text-secondary">
        No image
      </div>
    <% } %>
  </div>
  <div class="card-body d-flex flex-column">
    <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
      <h3 class="h5 mb-0"><%= item.title %></h3>
      <span class="badge rounded-pill text-bg-<%= item.type === 'lost' ? 'warning' : 'success' %>">
        <%= item.type %>
      </span>
    </div>
    <div class="d-flex gap-2 flex-wrap mb-2">
      <span class="badge text-bg-<%= item.isResolved ? 'secondary' : 'primary' %>"><%= item.status %></span>
    </div>
    <p class="small text-secondary mb-2"><%= item.category %> • <%= item.location %></p>
    <p class="item-card__description text-secondary flex-grow-1"><%= item.description %></p>
    <div class="d-flex justify-content-between align-items-center mt-3 gap-2 flex-wrap">
      <span class="small text-muted"><%= item.incidentDate %></span>
      <a href="/items/<%= item.id %>" class="btn btn-sm btn-outline-primary">View details</a>
    </div>

    <% if (ownerActionsEnabled) { %>
      <div class="d-grid gap-2 mt-3">
        <a href="/items/<%= item.id %>/edit" class="btn btn-sm btn-outline-secondary">Edit</a>
        <% if (!item.isResolved) { %>
          <form method="POST" action="/items/<%= item.id %>/resolve">
            <button type="submit" class="btn btn-sm btn-success w-100">Mark resolved</button>
          </form>
        <% } %>
        <form method="POST" action="/items/<%= item.id %>/delete" onsubmit="return confirm('Delete this listing permanently?');">
          <button type="submit" class="btn btn-sm btn-outline-danger w-100">Delete</button>
        </form>
      </div>
    <% } %>
  </div>
</article>
